{
  "name": "tree-sitter-twig",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaermorchen/tree-sitter-twig.git"
  },
  "version": "0.8.1",
  "description": "Twig grammar for tree-sitter",
  "scripts": {
    "build": "tree-sitter generate",
    "build-wasm": "tree-sitter build-wasm",
    "test": "tree-sitter generate && tree-sitter test"
  },
  "author": "Stanislav Romanov <kaermorchen@gmail.com>",
  "license": "Mozilla Public License 2.0",
  "devDependencies": {
    "nan": "^2.26.2",
    "tree-sitter-cli": "0.26.8"
  },
  "files": [
    "README.md",
    "LICENSE",
    "tree-sitter-twig.wasm"
  ],
  "tree-sitter": [
    {
      "scope": "twig",
      "file-types": [
        "twig",
        "html.twig"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injections": "queries/injections.scm",
      "injection-regex": "twig"
    }
  ]
}
